# Flask Configuration
FLASK_SECRET_KEY=generate-a-secure-random-key-here
FLASK_ENV=production

# Database Settings
# Use your Supabase PostgreSQL connection string in production
# format: postgresql://postgres:[password]@db.kypxmenwgtdhwbwmcorz.supabase.co:5432/postgres
DATABASE_URL=sqlite:///dev.db

# Google Gemini API Settings
# Get a key from Google AI Studio (https://aistudio.google.com/)
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key-here

# Toggle to False to enforce actual Gemini API calls in production
USE_GEMINI_SIMULATOR=False
